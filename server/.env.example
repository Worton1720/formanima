# ─── База данных ──────────────────────────────────────────────────────────────
# Строка подключения PostgreSQL. Порт 5434 соответствует docker-compose.yml.
DATABASE_URL="postgresql://formanima:secret@localhost:5434/formanima"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Секреты для подписи access- и refresh-токенов. В продакшене замените на
# длинные случайные строки (например: openssl rand -hex 32).
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"

# Время жизни токенов. Формат: <число><s|m|h|d>.
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ─── Сервер ───────────────────────────────────────────────────────────────────
# Порт HTTP-сервера. Необязательно, по умолчанию 3000.
PORT=3000

# Разрешённый источник для CORS. Необязательно, по умолчанию http://localhost:5173.
CORS_ORIGIN=http://localhost:5173
